NODE_ENV=production
PORT=3001

# Database
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=tada_user
DB_PASSWORD=
DB_NAME=tada_prod

# Redis
REDIS_PASSWORD=

# JWT
JWT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# Swagger basic auth (production only)
SWAGGER_USER=
SWAGGER_PASSWORD=

# Sentry (optional)
SENTRY_DSN=

# Email notifications (Resend)
RESEND_API_KEY=re_xxxx
NOTIFICATIONS_EMAIL=admin@tada.app
